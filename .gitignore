# TI Code Composer Studio build output (regenerated by CCS on every build)
Debug/
Release/

# Object files
*.obj
*.o

# Linker output
*.out
*.map

# Dependency files
*.d

# CCS build system generated makefiles
*.mk
makefile

# Preprocessor output
*.pp

# Assembly listings
*.lst

# Backups
*.bak

# OS / editor
Thumbs.db
.DS_Store

# NOTE: CCS project files (.project, .cproject, .ccsproject, .settings/,
# targetConfigs/, .launches/, lnk_*.cmd) are intentionally TRACKED so the
# project can be cloned and debugged on another machine with the same CCS
# version. Do not add them here.
